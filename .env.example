# Yeshua Architect Platform — Environment Variables

# OpenRouter (for live agent chat) — https://openrouter.ai/keys
OPENROUTER_API_KEY=...

# PoA Engine (optional, for receipts)
POA_ENGINE_URL=http://localhost:8000

# MIO Observer (optional, for residual tracking)
MIO_OBSERVER_URL=http://localhost:8787

# Database
DATABASE_PATH=data/platform.db

# App
APP_HOST=0.0.0.0
APP_PORT=8080
